# SeatFit Backend — Environment Variables
# Copy this file to .env and fill in real values

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seatfit
DB_USER=seatfit
DB_PASSWORD=seatfit_dev

# ── JWT ───────────────────────────────────────────────────
# IMPORTANT: Change this to a 256-bit random string in production!
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-in-production-minimum-256-bits

# ── CORS (comma-separated) ────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── OTP ───────────────────────────────────────────────────
OTP_DEV_MODE=true    # Set false in production — enables real SMS via MSG91

# ── Razorpay (add when ready) ─────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
